#!/usr/bin/env python3
"""Warn when skills-currency.yml claims are overdue for re-verification.

Pure date math over the manifest — no network (upstream verification is
/check-skill-currency's job, run manually; see docs/EVALS.md). Emits GitHub
Actions ::warning annotations plus plain text. ALWAYS exits 0: staleness is
a nudge to run the currency pass, never a broken build.

Thresholds are cadence + grace: monthly -> 45 days, quarterly -> 105 days.
Override today's date for testing: TODAY=YYYY-MM-DD bin/currency-staleness
"""

import os
import re
import sys
from datetime import date
from pathlib import Path

THRESHOLD_DAYS = {"monthly": 45, "quarterly": 105}

manifest = Path(__file__).resolve().parent.parent / "skills-currency.yml"
today = date.fromisoformat(os.environ["TODAY"]) if os.environ.get("TODAY") else date.today()

subject = cadence = None
stale = 0
for lineno, line in enumerate(manifest.read_text().splitlines(), 1):
    if m := re.match(r"\s+- subject: (.+)", line):
        subject, cadence = m.group(1).strip(), None
    elif m := re.match(r"\s+cadence: (\w+)", line):
        cadence = m.group(1)
    elif m := re.match(r"\s+last_verified: (\d{4}-\d{2}-\d{2})", line):
        if not (subject and cadence):
            continue
        limit = THRESHOLD_DAYS.get(cadence)
        if limit is None:
            print(f"::warning file=skills-currency.yml,line={lineno}::"
                  f"unknown cadence '{cadence}' on claim '{subject}'")
            stale += 1
            continue
        age = (today - date.fromisoformat(m.group(1))).days
        if age > limit:
            print(f"::warning file=skills-currency.yml,line={lineno}::"
                  f"claim '{subject}' last verified {m.group(1)} — {age}d ago "
                  f"(> {limit}d for {cadence} cadence); run /check-skill-currency")
            stale += 1

print(f"currency staleness: {stale} overdue claim(s)" if stale
      else "currency staleness: all claims within cadence")
sys.exit(0)
