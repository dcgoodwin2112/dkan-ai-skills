#!/usr/bin/env bash
# Generate per-agent-tool adapter files from the canonical Claude plugin source
# (plugins/drupal-dkan-ai/skills + commands). Outputs:
#
#   AGENTS.md                                  # broad: Codex, Cursor, Gemini, Aider, Zed, ...
#   .github/copilot-instructions.md            # GitHub Copilot, repo-wide
#   .github/instructions/<skill>.instructions.md   # Copilot, path-scoped (applyTo)
#   .github/prompts/<command>.prompt.md        # Copilot, invokable prompts
#
# The skill adapters are intentionally THIN: they point at the canonical
# reference/*.md docs so those stay single-sourced. Prompt files inline the
# command body (a prompt file IS the prompt) with $ARGUMENTS mapped to Copilot's
# ${input:args}.
#
# Usage: bin/build-adapters [output-root]
#   output-root defaults to the repo root. bin/test passes a temp dir to diff
#   the result against the committed files (stale check).
#
# Re-run after editing any SKILL.md or command. Outputs are committed.

set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
out="${1:-$repo_root}"

plugin_rel="plugins/drupal-dkan-ai"
skills_dir="$repo_root/$plugin_rel/skills"
commands_dir="$repo_root/$plugin_rel/commands"

gen_marker="<!-- GENERATED by bin/build-adapters from $plugin_rel — do not edit; re-run the script -->"

# Extract a single-line frontmatter scalar (strips surrounding quotes).
fm_field() {
  awk -v field="$1" '
    NR==1 && $0=="---" { infm=1; next }
    infm && $0=="---"  { exit }
    infm && $0 ~ "^" field ": " {
      sub("^" field ": *", ""); gsub(/^"|"$|^'\''|'\''$/, ""); print; exit
    }' "$2"
}

# Body after the frontmatter block.
md_body() {
  awk '
    NR==1 && $0=="---" { infm=1; next }
    infm && $0=="---"  { infm=0; started=1; next }
    started { print }' "$1"
}

# Copilot applyTo glob per skill (prose triggers don't map to globs mechanically;
# curated here — keep in sync when adding a skill).
skill_glob() {
  case "$1" in
    dkan-module-author)    echo '**/modules/custom/**,**/modules/contrib/dkan/**' ;;
    dkan-core-contributor) echo '**/modules/contrib/dkan/**,**/dkan/modules/dkan_*/**' ;;
    drupal-ai-module)      echo '**/modules/custom/**' ;;
    drupal-mcp-server)     echo '**/modules/custom/**,**/modules/contrib/mcp_server/**' ;;
    *)                     echo '**' ;;
  esac
}

mkdir -p "$out/.github/instructions" "$out/.github/prompts"

# ---- AGENTS.md (broad cross-tool) -----------------------------------------
agents="$out/AGENTS.md"
{
  echo "$gen_marker"
  echo
  echo "# AGENTS.md"
  echo
  echo "Reference and scaffolding guidance for writing custom Drupal modules that extend"
  echo "DKAN 4.x, the Drupal AI module, and the MCP Server module — plus contributing to DKAN core itself. This repo's canonical source is a Claude Code"
  echo "plugin under \`$plugin_rel/\`; the guidance below is tool-neutral and applies to any"
  echo "coding agent (Codex, Cursor, Gemini CLI, Aider, Zed, …)."
  echo
  echo "When a task matches a domain below, read the linked \`SKILL.md\` and its \`reference/\`"
  echo "docs before writing code — they carry DKAN/Drupal-AI specifics that aren't obvious"
  echo "from the code alone."
  echo
  echo "## Skills"
  for d in "$skills_dir"/*/; do
    name="$(basename "$d")"
    desc="$(fm_field description "$d/SKILL.md")"
    echo
    echo "### $name"
    echo
    echo "$desc"
    echo
    echo "- Guide: [\`$plugin_rel/skills/$name/SKILL.md\`]($plugin_rel/skills/$name/SKILL.md)"
    if [[ -d "$d/reference" ]]; then
      echo "- Reference docs:"
      for ref in "$d"/reference/*.md; do
        [[ -e "$ref" ]] || continue
        rname="$(basename "$ref")"
        echo "  - [\`$rname\`]($plugin_rel/skills/$name/reference/$rname)"
      done
    fi
  done
  echo
  echo "## Scaffolding & validation procedures"
  echo
  echo "These are reusable procedures (Claude slash commands; mirrored as Copilot prompt"
  echo "files under \`.github/prompts/\`). To run one in a plain-agent context, read the"
  echo "command file and follow its steps with the given arguments."
  echo
  echo "| Procedure | Arguments | Source |"
  echo "|---|---|---|"
  for f in "$commands_dir"/*.md; do
    cname="$(basename "$f" .md)"
    desc="$(fm_field description "$f")"
    hint="$(fm_field argument-hint "$f")"
    echo "| $desc | \`$hint\` | [\`$cname.md\`]($plugin_rel/commands/$cname.md) |"
  done
} > "$agents"

# ---- .github/copilot-instructions.md (repo-wide) --------------------------
copilot="$out/.github/copilot-instructions.md"
{
  echo "$gen_marker"
  echo
  echo "# Copilot instructions: DKAN 4.x + Drupal AI + MCP Server authoring + DKAN core contribution"
  echo
  echo "This repository packages skills, reference docs, and scaffolding procedures for"
  echo "writing custom Drupal modules that extend DKAN 4.x, the Drupal AI module"
  echo "(\`drupal/ai\`, \`ai_agents\`), and the MCP Server module (\`drupal/mcp_server\`),"
  echo "plus contributing to DKAN core itself (the \`drupal/dkan\` package)."
  echo "Canonical source lives under \`$plugin_rel/\`."
  echo
  echo "Path-scoped instructions in \`.github/instructions/\` auto-attach when you edit"
  echo "matching files. Reusable procedures are in \`.github/prompts/\` (run with \`/<name>\`)."
  echo "For the full picture see [\`AGENTS.md\`](../AGENTS.md)."
  echo
  echo "When working on DKAN, Drupal-AI, or MCP Server module code, consult the reference"
  echo "docs under \`$plugin_rel/skills/*/reference/\` — they carry version-specific specifics"
  echo "(DKAN 4.x \`Drupal\\dkan_*\` namespaces, \`drupal/ai 1.3.x\` lifecycle, \`mcp_server\`/"
  echo "\`mcp/sdk\` 0.6 volatility) that prevent common mistakes."
} > "$copilot"

# ---- .github/instructions/<skill>.instructions.md -------------------------
for d in "$skills_dir"/*/; do
  name="$(basename "$d")"
  desc="$(fm_field description "$d/SKILL.md")"
  glob="$(skill_glob "$name")"
  inst="$out/.github/instructions/$name.instructions.md"
  {
    echo "---"
    echo "name: '$name'"
    echo "description: '$(printf '%s' "$desc" | sed "s/'/''/g")'"
    echo "applyTo: '$glob'"
    echo "---"
    echo
    echo "$gen_marker"
    echo
    echo "$desc"
    echo
    echo "Before writing or modifying code here, read the canonical guide and its detail docs:"
    echo
    echo "- Guide: \`$plugin_rel/skills/$name/SKILL.md\`"
    if [[ -d "$d/reference" ]]; then
      for ref in "$d"/reference/*.md; do
        [[ -e "$ref" ]] || continue
        rname="$(basename "$ref")"
        echo "- \`$plugin_rel/skills/$name/reference/$rname\`"
      done
    fi
    echo
    echo "These docs are the single source of truth; do not restate their contents here."
  } > "$inst"
done

# ---- .github/prompts/<command>.prompt.md ----------------------------------
for f in "$commands_dir"/*.md; do
  cname="$(basename "$f" .md)"
  desc="$(fm_field description "$f")"
  hint="$(fm_field argument-hint "$f")"
  prompt="$out/.github/prompts/$cname.prompt.md"
  {
    echo "---"
    echo "description: '$(printf '%s' "$desc" | sed "s/'/''/g")'"
    echo "argument-hint: '$(printf '%s' "$hint" | sed "s/'/''/g")'"
    echo "agent: 'agent'"
    echo "---"
    echo
    echo "$gen_marker"
    echo
    # Inline the command body; map Claude's $ARGUMENTS to Copilot's input var.
    md_body "$f" | sed 's/\$ARGUMENTS/${input:args}/g'
  } > "$prompt"
done

echo "Generated adapters under: $out"
echo "  AGENTS.md"
echo "  .github/copilot-instructions.md"
echo "  .github/instructions/*.instructions.md ($(ls -1 "$skills_dir" | wc -l | tr -d ' ') skills)"
echo "  .github/prompts/*.prompt.md ($(ls -1 "$commands_dir"/*.md | wc -l | tr -d ' ') commands)"
