#!/usr/bin/env bash
# Fallback installer: symlink the plugin's commands/ and skills/ into a target
# .claude/ directory, for setups that don't use the Claude Code plugin system.
#
# PREFERRED install is the plugin marketplace (see README):
#   claude plugin marketplace add <this repo>
#   claude plugin install drupal-dkan-ai@dkan-ai-skills
#
# Usage:
#   bin/install [--adapters] [target-dir]
#
# target-dir defaults to "$PWD/.claude" (per-project). Pass "$HOME/.claude" to
# make the skills/commands available to every project on the machine. The script
# creates <target>/commands/ and <target>/skills/, then symlinks each command .md
# and each skill directory using absolute paths. Existing symlinks pointing at
# this repo are replaced; existing non-symlink entries are left alone and reported.
#
# --adapters additionally writes cross-tool adapter files (AGENTS.md, .github/)
# into the current project ($PWD) for Copilot/Codex/Cursor/etc., vendoring the
# skills+commands under .ai/dkan-ai-skills/ so the docs travel with the project.

set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"

do_adapters=0
target=""
for arg in "$@"; do
  case "$arg" in
    --adapters) do_adapters=1 ;;
    *) target="$arg" ;;
  esac
done
target="${target:-$PWD/.claude}"

commands_src="$repo_root/plugins/drupal-dkan-ai/commands"
skills_src="$repo_root/plugins/drupal-dkan-ai/skills"

if [[ ! -d "$commands_src" || ! -d "$skills_src" ]]; then
  echo "error: expected $commands_src and $skills_src to exist" >&2
  exit 1
fi

mkdir -p "$target/commands" "$target/skills"

link_one() {
  local src="$1" dest="$2"
  if [[ -L "$dest" ]]; then
    local current
    current="$(readlink "$dest")"
    if [[ "$current" == "$src" ]]; then
      echo "  ok      $dest"
      return 0
    fi
    ln -sfn "$src" "$dest"
    echo "  relink  $dest"
    return 0
  fi
  if [[ -e "$dest" ]]; then
    echo "  skip    $dest (exists, not a symlink)" >&2
    return 0
  fi
  ln -s "$src" "$dest"
  echo "  link    $dest"
}

echo "Installing into $target"
echo "Commands:"
shopt -s nullglob
for f in "$commands_src"/*.md; do
  link_one "$f" "$target/commands/$(basename "$f")"
done

echo "Skills:"
for d in "$skills_src"/*/; do
  name="$(basename "$d")"
  link_one "${d%/}" "$target/skills/$name"
done

if [[ $do_adapters -eq 1 ]]; then
  proj="$PWD"
  vendor=".ai/dkan-ai-skills"
  echo "Adapters (into $proj):"
  mkdir -p "$proj/$vendor" "$proj/.github/instructions" "$proj/.github/prompts"
  # Vendor the canonical content so adapter pointers resolve in this project.
  ln -sfn "$skills_src" "$proj/$vendor/skills"
  ln -sfn "$commands_src" "$proj/$vendor/commands"
  echo "  vendor  $vendor/{skills,commands}"

  write_adapter() {
    local rel="$1" dest="$proj/$1"
    if [[ -e "$dest" ]] && ! grep -q 'GENERATED by bin/build-adapters' "$dest" 2>/dev/null; then
      echo "  skip    $rel (exists, not generated by this tool)" >&2
      return 0
    fi
    mkdir -p "$(dirname "$dest")"
    # Rewrite the in-repo path base to the vendored location.
    sed 's#plugins/drupal-dkan-ai/#.ai/dkan-ai-skills/#g' "$repo_root/$rel" > "$dest"
    echo "  write   $rel"
  }

  write_adapter "AGENTS.md"
  write_adapter ".github/copilot-instructions.md"
  for f in "$repo_root"/.github/instructions/*.instructions.md; do
    write_adapter ".github/instructions/$(basename "$f")"
  done
  for f in "$repo_root"/.github/prompts/*.prompt.md; do
    write_adapter ".github/prompts/$(basename "$f")"
  done
fi

echo "Done."
