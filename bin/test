#!/usr/bin/env bash
# Test bin/install: fresh install, idempotent re-run, conflict handling,
# repointing of stale symlinks, and custom target argument.
#
# Each test creates a fresh tmp dir and asserts on the script's output
# and the resulting filesystem state. Prints "PASS" / "FAIL" per case
# and exits non-zero on any failure.

set -uo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
install="$repo_root/bin/install"

fails=0
tmp_dirs=()

cleanup() {
  for d in ${tmp_dirs[@]+"${tmp_dirs[@]}"}; do
    [[ -d "$d" ]] && rm -rf "$d"
  done
}
trap cleanup EXIT

fresh_tmp() {
  local d
  d="$(mktemp -d)"
  tmp_dirs+=("$d")
  echo "$d"
}

assert() {
  local label="$1" cond="$2"
  if eval "$cond"; then
    echo "  PASS  $label"
  else
    echo "  FAIL  $label  [$cond]"
    fails=$((fails + 1))
  fi
}

count_commands() { find "$repo_root/plugins/drupal-dkan-ai/commands" -maxdepth 1 -name '*.md' | wc -l | tr -d ' '; }
count_skills()   { find "$repo_root/plugins/drupal-dkan-ai/skills" -mindepth 1 -maxdepth 1 -type d | wc -l | tr -d ' '; }

expected_cmds=$(count_commands)
expected_skills=$(count_skills)

echo "Test 1: fresh install into default target (\$PWD/.claude)"
target="$(fresh_tmp)"
(cd "$target" && "$install" >/tmp/install.out 2>&1)
actual_cmds=$(find "$target/.claude/commands" -maxdepth 1 -type l | wc -l | tr -d ' ')
actual_skills=$(find "$target/.claude/skills" -maxdepth 1 -type l | wc -l | tr -d ' ')
assert "creates .claude/commands with all command symlinks" "[[ $actual_cmds -eq $expected_cmds ]]"
assert "creates .claude/skills with all skill symlinks"     "[[ $actual_skills -eq $expected_skills ]]"
assert "symlinks resolve to repo files"                    "[[ \"$(readlink "$target/.claude/commands/validate-module.md")\" == \"$repo_root/plugins/drupal-dkan-ai/commands/validate-module.md\" ]]"
assert "symlink target file is readable through the link"  "[[ -f \"$target/.claude/commands/validate-module.md\" ]]"

echo "Test 2: idempotent re-run prints only 'ok'"
"$install" "$target/.claude" >/tmp/install.out 2>&1
assert "no 'link' lines on second run"   "! grep -q '^  link '   /tmp/install.out"
assert "no 'relink' lines on second run" "! grep -q '^  relink ' /tmp/install.out"
assert "no 'skip' lines on second run"   "! grep -q '^  skip '   /tmp/install.out"
assert "has 'ok' lines on second run"    "grep -q '^  ok ' /tmp/install.out"

echo "Test 3: custom target arg"
parent="$(fresh_tmp)"
alt="$parent/alt-dir"
"$install" "$alt" >/dev/null
actual_cmds=$(find "$alt/commands" -maxdepth 1 -type l | wc -l | tr -d ' ')
assert "custom target gets all commands" "[[ $actual_cmds -eq $expected_cmds ]]"
assert "default .claude was NOT created next to alt" "[[ ! -d \"$parent/.claude\" ]]"

echo "Test 4: non-symlink conflict is skipped, not overwritten"
target="$(fresh_tmp)"
mkdir -p "$target/.claude/commands"
echo "user content" > "$target/.claude/commands/validate-module.md"
"$install" "$target/.claude" >/tmp/install.out 2>&1
assert "real file is not overwritten" "[[ \"\$(cat \"$target/.claude/commands/validate-module.md\")\" == 'user content' ]]"
assert "skip line printed to stderr"   "grep -q 'skip.*validate-module.md.*exists, not a symlink' /tmp/install.out"
assert "other commands still linked"   "[[ -L \"$target/.claude/commands/ai-scaffold-tool.md\" ]]"

echo "Test 5: stale symlink is repointed"
target="$(fresh_tmp)"
mkdir -p "$target/.claude/commands"
ln -s "/nonexistent/old/path/validate-module.md" "$target/.claude/commands/validate-module.md"
"$install" "$target/.claude" >/tmp/install.out 2>&1
assert "stale symlink was relinked" "grep -q '^  relink .*validate-module.md' /tmp/install.out"
assert "new target points at repo"  "[[ \"\$(readlink "$target/.claude/commands/validate-module.md")\" == \"$repo_root/plugins/drupal-dkan-ai/commands/validate-module.md\" ]]"

echo "Test 6: missing source directories exits with error"
broken="$(mktemp -d)"
mkdir -p "$broken/bin"
cp "$install" "$broken/bin/install"
chmod +x "$broken/bin/install"
out_file=$(mktemp)
set +e
"$broken/bin/install" "$broken/.claude" >"$out_file" 2>&1
rc=$?
set -e
assert "exits non-zero when plugins/drupal-dkan-ai/commands and skills missing" "[[ $rc -ne 0 ]]"
assert "prints error to stderr"                                    "grep -q 'expected' \"$out_file\""
rm -rf "$broken" "$out_file"

echo "Test 7: committed adapters are not stale (bin/build-adapters output matches)"
build="$repo_root/bin/build-adapters"
gen="$(fresh_tmp)"
"$build" "$gen" >/dev/null 2>&1
stale=0
while IFS= read -r rel; do
  if ! diff -q "$repo_root/$rel" "$gen/$rel" >/dev/null 2>&1; then
    echo "    drift: $rel" >&2
    stale=$((stale + 1))
  fi
done < <(cd "$gen" && find AGENTS.md .github -type f | sort)
assert "generated adapters match committed (run bin/build-adapters)" "[[ $stale -eq 0 ]]"

echo "Test 8: dependency-gate hook decisions"
hook="$repo_root/plugins/drupal-dkan-ai/hooks/dependency-gate.sh"
if ! command -v jq >/dev/null 2>&1; then
  echo "  SKIP  jq not installed"
else
  gate_verdict()     { jq -Rn --arg c "$1" '{tool_input:{command:$c}}' | CLAUDE_GATE_DRYRUN=1 bash "$hook" 2>&1; }
  gate_exit()        { jq -Rn --arg c "$1" '{tool_input:{command:$c}}' | { bash "$hook" >/dev/null 2>&1; echo $?; }; }
  gate_exit_bypass() { jq -Rn --arg c "$1" '{tool_input:{command:$c}}' | { CLAUDE_SKIP_DEP_GATE=1 bash "$hook" >/dev/null 2>&1; echo $?; }; }

  # Package-adding commands must be gated (incl. wrapper, quoted, nested-shell,
  # and `python -m pip` forms).
  for c in \
    'composer require drupal/foo' 'npm install left-pad' 'ddev composer require x/y' \
    'yarn add vue' 'pip install requests' 'python -m pip install requests' \
    'python3 -m pip install flask' '"npm" install evil' 'bash -c "npm install evil"' \
    'uv add ruff' 'uv pip install requests' 'uv tool install black' \
    'poetry add flask' 'pipx install black' 'deno add npm:left-pad'; do
    assert "blocks: $c" "gate_verdict '$c' | grep -q 'WOULD GATE'"
  done
  # Lockfile-driven / non-install commands must pass.
  for c in \
    'composer install' 'npm install' 'npm install --prefix frontend' \
    'pip install -r requirements.txt' 'go install ./...' 'git commit -m "npm install foo"' \
    'uv pip install -r requirements.txt' 'uv sync' 'poetry install' \
    'pipx run black' 'deno install' 'deno task build'; do
    assert "allows: $c" "gate_verdict '$c' | grep -q 'would allow'"
  done
  assert "block returns exit 2"  "[[ \"\$(gate_exit 'composer require x/y')\" == 2 ]]"
  assert "allow returns exit 0"  "[[ \"\$(gate_exit 'composer install')\" == 0 ]]"
  assert "bypass returns exit 0" "[[ \"\$(gate_exit_bypass 'composer require x/y')\" == 0 ]]"
fi

echo "Test 9: commit-gate detection + scoping"
cg="$repo_root/plugins/drupal-dkan-ai/hooks/commit-gate.sh"
if ! command -v jq >/dev/null 2>&1; then
  echo "  SKIP  jq not installed"
elif ! command -v git >/dev/null 2>&1; then
  echo "  SKIP  git not installed"
else
  cgrepo="$(fresh_tmp)"
  (
    cd "$cgrepo" || exit 1
    git init -q
    git config user.email t@t.t
    git config user.name t
    mkdir -p .ddev modules/custom/foo
    printf 'name: x\n' > .ddev/config.yaml
    printf '<?xml/>\n' > modules/custom/foo/phpcs.xml.dist
    printf '<?php\n' > modules/custom/foo/foo.module
    git add modules/custom/foo/foo.module
  )
  cg_dry()    { jq -nc --arg c "$1" --arg w "$cgrepo" '{tool_input:{command:$c},cwd:$w}' | CLAUDE_GATE_DRYRUN=1 bash "$cg" 2>&1; }
  cg_bypass() { jq -nc --arg c "$1" --arg w "$cgrepo" '{tool_input:{command:$c},cwd:$w}' | CLAUDE_SKIP_COMMIT_GATE=1 bash "$cg" 2>&1; }
  # Capture-then-match (not `| grep -q`): with pipefail, grep -q's early exit can
  # SIGPIPE the producer and flip the pipeline status on an early-line match.
  assert "gates a real commit"                "[[ \"\$(cg_dry 'git commit -m x')\" == *'would gate'* ]]"
  assert "gate names the touched module"      "[[ \"\$(cg_dry 'git commit -m x')\" == *'modules/custom/foo'* ]]"
  assert "ignores 'git status'"               "[[ \"\$(cg_dry 'git status')\" != *'would gate'* ]]"
  assert "ignores 'git log --grep commit'"    "[[ \"\$(cg_dry 'git log --grep commit')\" != *'would gate'* ]]"
  assert "ignores 'git commit-tree' plumbing" "[[ \"\$(cg_dry 'git commit-tree abc')\" != *'would gate'* ]]"
  assert "bypass env skips the gate"          "[[ \"\$(cg_bypass 'git commit -m x')\" == *bypassed* ]]"
fi

echo
if [[ $fails -eq 0 ]]; then
  echo "All tests passed."
  exit 0
else
  echo "$fails test(s) failed."
  exit 1
fi
