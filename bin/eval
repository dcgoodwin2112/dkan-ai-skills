#!/usr/bin/env bash
# Skill-effectiveness eval runner for dkan-ai-skills.
#
# Subcommands:
#   task              Regrade the recorded task-outcome runs (benchmark.json).
#                     Deterministic, no auth — operates on
#                     evals/tasks/runs/raw_runs.json. Collect fresh runs
#                     in-session first (see docs/EVALS.md).
#
#   scaffolds         Scaffold-correctness gate (no auth, no deps — runs
#                     anywhere). Deterministic string/regex assertions over each
#                     scaffold command's embedded code templates: required
#                     attribute / base class / method signature / version-gate
#                     present, and the fabricated forms the Pitfall lists warn
#                     about absent. Optionally lints REAL generated output with
#                     phpcs where a Drupal/DDEV env exists (skip-guarded).
#
#   live              Live-currency gate (env-gated; no auth, no LLM, no tokens
#                     — runs fine inside a Claude Code session). Verifies the
#                     skill docs' factual claims about the DKAN/MCP surface
#                     against a RUNNING DKAN dev site over MCP stdio plus three
#                     curl probes; strictly read-only (the writer connection is
#                     used for tools/list only). SKIPs cleanly when no site is
#                     configured; exits 2 if configured but unreachable.
#
# Scaffold phpcs layer (optional, skip-guarded — mirrors bin/test's jq/git skips):
#   EVAL_PHPCS                phpcs command (e.g. "ddev exec vendor/bin/phpcs");
#                             defaults to `phpcs` on PATH, skips if neither found.
#   EVAL_SCAFFOLD_OUTPUT_DIR  dir of generated scaffold output to lint; unset ->
#                             phpcs layer skips cleanly (structural gate still runs).
#
# Live gate env (see docs/EVALS.md for details):
#   EVAL_DKAN_SITE_DIR        DKAN site checkout (DDEV); unset -> clean SKIP.
#   EVAL_DKAN_MCP_CMD_RO/_RW  stdio command overrides (default: ddev drush
#                             dkan-mcp-server:serve --user=mcp_reader|mcp_writer).
#   EVAL_DKAN_SITE_URL        site base URL (default: derived from .ddev/config.yaml).
#   EVAL_DKAN_MCP_HTTP_PATH   MCP endpoint path (default /mcp).
#   EVAL_DKAN_BASIC_PROBE     "user:pass" for the Basic-rejected probes; unset -> skip.

set -uo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
evals_dir="$repo_root/evals"

die() { echo "error: $*" >&2; exit 1; }

cmd_scaffolds() {
  command -v python3 >/dev/null 2>&1 || die "python3 not found"

  # ---- Enforced gate: deterministic checks over the shipped command templates.
  # No PHP/DDEV/network — runs anywhere. Non-zero exit fails the gate.
  echo "== scaffold-correctness gate (deterministic) ==" >&2
  python3 "$evals_dir/lib/check_scaffolds.py"
  local rc=$?
  [[ $rc -eq 0 ]] || return "$rc"

  # ---- Optional layer: phpcs-lint REAL generated output where a Drupal/DDEV
  # env exists. Mirrors bin/test's jq/git skip pattern — absent tooling yields a
  # clean SKIP, never a false failure. The gate above already validated the
  # templates; this validates concrete generated code when you have some.
  local phpcs_cmd=""
  if [[ -n "${EVAL_PHPCS:-}" ]]; then
    phpcs_cmd="$EVAL_PHPCS"
  elif command -v phpcs >/dev/null 2>&1; then
    phpcs_cmd="phpcs"
  fi
  local out_dir="${EVAL_SCAFFOLD_OUTPUT_DIR:-}"

  echo >&2
  if [[ -z "$phpcs_cmd" ]]; then
    echo "  SKIP  phpcs — no phpcs found (set EVAL_PHPCS, e.g. \"ddev exec vendor/bin/phpcs\")" >&2
    return 0
  fi
  if [[ -z "$out_dir" ]]; then
    echo "  SKIP  phpcs — set EVAL_SCAFFOLD_OUTPUT_DIR to a dir of generated scaffold output to lint" >&2
    return 0
  fi
  [[ -d "$out_dir" ]] || die "EVAL_SCAFFOLD_OUTPUT_DIR is not a directory: $out_dir"

  echo "== phpcs --standard=Drupal,DrupalPractice: $out_dir ==" >&2
  # shellcheck disable=SC2086
  $phpcs_cmd --standard=Drupal,DrupalPractice "$out_dir"
  local prc=$?
  [[ $prc -eq 0 ]] || die "phpcs reported violations in $out_dir (rc=$prc)"
  echo "   phpcs clean" >&2
}

cmd_live() {
  command -v python3 >/dev/null 2>&1 || die "python3 not found"
  echo "== live-currency gate (skill docs vs running DKAN over MCP) ==" >&2
  python3 "$evals_dir/lib/check_live.py"
  return $?
}

cmd_task() {
  command -v python3 >/dev/null 2>&1 || die "python3 not found"
  echo "== task-outcome benchmark: regrade recorded runs ==" >&2
  python3 "$evals_dir/lib/grade_tasks.py" || die "grade_tasks.py failed"
  echo "   -> evals/tasks/benchmark.json" >&2
  echo "   (collect fresh runs in-session before regrading — see docs/EVALS.md)" >&2
}

case "${1:-}" in
  task)      shift; cmd_task ;;
  scaffolds) shift; cmd_scaffolds ;;
  live)      shift; cmd_live ;;
  *) echo "usage: bin/eval <task | scaffolds | live>" >&2; exit 2 ;;
esac
