      "note": "the read/write OAuth scopes are advertised for discovery",
      "skill": "drupal-mcp-server",
      "doc_ref": "plugins/drupal-dkan-ai/skills/drupal-mcp-server/reference/auth-and-access.md"
    },
    {
      "id": "doc_no_old_serve_cmd",
      "group": "doc_tripwire",
      "probe": "doc",
      "path": "plugins/drupal-dkan-ai/skills/drupal-mcp-server/reference/dkan-integration.md",
      "assert": "must_not_match",
      "re": "dkan-mcp:serve",
      "neg_example": "stdio via **`drush dkan-mcp:serve`**",
      "note": "live serve command is dkan-mcp-server:serve (the regex cannot substring-match it: ':serve' must follow 'dkan-mcp')",
      "skill": "drupal-mcp-server"
    },
    {
