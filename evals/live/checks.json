      "group": "doc_tripwire",
      "probe": "doc",
      "path": "plugins/drupal-dkan-ai/skills/drupal-mcp-server/SKILL.md",
      "assert": "must_not_match",
      "re": "~35 ",
      "neg_example": "exposing ~35 metastore/datastore/harvest tools",
      "note": "SKILL.md repeats the stale ~35 count",
      "skill": "drupal-mcp-server"
    },
    {
      "id": "doc_names_current_serve_cmd",
      "group": "doc_tripwire",
      "probe": "doc",
      "path": "plugins/drupal-dkan-ai/skills/drupal-mcp-server/reference/dkan-integration.md",
