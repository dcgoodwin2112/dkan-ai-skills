      "probe": "http.prm",
      "extract": "json",
      "op": "contains",
      "expected": ["resource"],
      "note": "PRM document carries the required 'resource' member",
      "skill": "drupal-mcp-server",
      "doc_ref": "plugins/drupal-dkan-ai/skills/drupal-mcp-server/reference/auth-and-access.md"
    },
    {
      "id": "prm_scopes",
      "group": "site_posture",
      "probe": "http.prm",
      "extract": "json.scopes_supported",
      "op": "contains",
